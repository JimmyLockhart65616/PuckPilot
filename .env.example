# Yahoo developer app credentials — create one at https://developer.yahoo.com/apps/create/
#   Application Type: Confidential Client (Web Application)
#   Redirect URI: https://localhost:8000 (OOB flow never actually calls it)
#   API Permissions: Fantasy Sports -> Read/Write
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# Your league ID: from your league URL, e.g. hockey.fantasysports.yahoo.com/hockey/12345 -> 12345
YAHOO_LEAGUE_ID=
